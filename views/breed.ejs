<%- include("partials/header") %>

<%- include("partials/navbar") %>

<section class="about">

    <div class="card details-card">

        <img
            src="<%= breed.image_url %>"
            alt="<%= breed.name %>">

        <div class="card-content">

            <h2><%= breed.name %></h2>

            <p>
                <strong>Origin:</strong>
                <%= breed.origin %>
            </p>

            <p>
                <strong>Life Span:</strong>
                <%= breed.details.lifespan %>
            </p>

            <p>
                <strong>Weight:</strong>
                <%= breed.details.weight %>
            </p>

            <p>
                <strong>Coat Type:</strong>
                <%= breed.details.coatType %>
            </p>

            <p>
                <strong>Grooming:</strong>
                <%= breed.details.groomingLevel %>
            </p>

            <p>
                <strong>Temperament:</strong>
                <%= breed.temperament %>
            </p>

            <p>
                <%= breed.description %>
            </p>

            <p>

                <strong>Tags:</strong>

                <%= breed.tags.join(", ") %>

            </p>

            <a href="/breeds" class="btn">

                ← Back

            </a>

        </div>

    </div>

</section>

<%- include("partials/footer") %>