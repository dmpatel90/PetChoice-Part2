<%- include("partials/header") %>

<%- include("partials/navbar") %>

<!-- ==========================================
     BREEDS PAGE
========================================== -->

<section class="about">

    <h1 class="about-title">

        🐱 Browse Cat Breeds

    </h1>

    <p style="text-align:center; margin-bottom:30px;">

        Explore <strong><%= breeds.length %></strong> cat breeds and learn
        about their origin, temperament, lifespan, coat type, and more.

    </p>

    <div id="catsContainer">

        <% breeds.forEach(breed => { %>

            <div class="card">

                <img
                    src="<%= breed.image_url %>"
                    alt="<%= breed.name %>">

                <div class="card-content">

                    <h3>

                        <%= breed.name %>

                    </h3>

                    <p>

                        <strong>Origin:</strong>
                        <%= breed.origin %>

                    </p>

                    <p>

                        <strong>Life Span:</strong>
                        <%= breed.details.lifespan %>

                    </p>

                    <p>

                        <strong>Weight:</strong>
                        <%= breed.details.weight %>

                    </p>

                    <p>

                        <strong>Coat Type:</strong>
                        <%= breed.details.coatType %>

                    </p>

                    <p>

                        <strong>Temperament:</strong>
                        <%= breed.temperament %>

                    </p>

                    <p>

                        <%= breed.description.substring(0, 120) %>...

                    </p>

                    <a
                        href="/breeds/<%= breed.id %>"
                        class="btn">

                        View Details

                    </a>

                </div>

            </div>

        <% }) %>

    </div>

</section>

<%- include("partials/footer") %>