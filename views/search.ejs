<%- include("partials/header") %>

<%- include("partials/navbar") %>

<section class="about">

    <h1 class="about-title">
        🔍 Search Cat Breeds
    </h1>

    <p style="text-align:center; margin-bottom:30px;">
        Search cat breeds using the filters below.
    </p>

    <form action="/search" method="POST" class="controls">

        <input
            type="text"
            name="keyword"
            placeholder="Search by breed or temperament..."
            value="<%= keyword %>">

        <select name="origin">

            <option value="">All Origins</option>

            <% origins.forEach(item => { %>

                <option
                    value="<%= item %>"
                    <%= item === origin ? "selected" : "" %>>

                    <%= item %>

                </option>

            <% }) %>

        </select>

        <select name="coatType">

            <option value="">All Coat Types</option>

            <% coatTypes.forEach(item => { %>

                <option
                    value="<%= item %>"
                    <%= item === coatType ? "selected" : "" %>>

                    <%= item %>

                </option>

            <% }) %>

        </select>

        <select name="grooming">

            <option value="">All Grooming Levels</option>

            <% groomingLevels.forEach(item => { %>

                <option
                    value="<%= item %>"
                    <%= item === grooming ? "selected" : "" %>>

                    <%= item %>

                </option>

            <% }) %>

        </select>

        <button type="submit">

            Search

        </button>

        <a href="/search" class="btn">

            Reset

        </a>

    </form>

    <br>

    <% if(results.length > 0){ %>

        <h3 style="text-align:center; margin-bottom:20px;">

            <%= results.length %> breed(s) found

        </h3>

        <div id="catsContainer">

            <% results.forEach(breed => { %>

                <div class="card">

                    <img
                        src="<%= breed.image_url %>"
                        alt="<%= breed.name %>">

                    <div class="card-content">

                        <h3><%= breed.name %></h3>

                        <p>

                            <strong>Origin:</strong>

                            <%= breed.origin %>

                        </p>

                        <p>

                            <strong>Life Span:</strong>

                            <%= breed.details.lifespan %>

                        </p>

                        <p>

                            <strong>Coat:</strong>

                            <%= breed.details.coatType %>

                        </p>

                        <p>

                            <strong>Temperament:</strong>

                            <%= breed.temperament %>

                        </p>

                        <a
                            href="/breeds/<%= breed.id %>"
                            class="btn">

                            View Details

                        </a>

                    </div>

                </div>

            <% }) %>

        </div>

    <% } else if(keyword || origin || coatType || grooming){ %>

        <h2 style="text-align:center; color:#ff914d;">

            No breeds found.

        </h2>

    <% } %>

</section>

<%- include("partials/footer") %>