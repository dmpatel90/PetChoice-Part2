<%- include("partials/header") %>

<%- include("partials/navbar") %>

<section class="search-section">

    <h1 class="about-title">

        🔍 Search Cat Breeds

    </h1>

    <form action="/search" method="POST" class="controls">

        <input
            type="text"
            name="keyword"
            placeholder="Search breed, origin or temperament..."
            value="<%= keyword %>">

        <!-- Origin -->

        <select name="origin">

            <option value="">All Origins</option>

            <% origins.forEach(item => { %>

                <option
                    value="<%= item %>"
                    <%= item === origin ? "selected" : "" %>>

                    <%= item %>

                </option>

            <% }) %>

        </select>

        <!-- Coat -->

        <select name="coatType">

            <option value="">All Coat Types</option>

            <% coatTypes.forEach(item => { %>

                <option
                    value="<%= item %>"
                    <%= item === coatType ? "selected" : "" %>>

                    <%= item %>

                </option>

            <% }) %>

        </select>

        <!-- Grooming -->

        <select name="grooming">

            <option value="">All Grooming Levels</option>

            <% groomingLevels.forEach(item => { %>

                <option
                    value="<%= item %>"
                    <%= item === grooming ? "selected" : "" %>>

                    <%= item %>

                </option>

            <% }) %>

        </select>

        <button type="submit">

            Search

        </button>

        <a href="/search" class="btn">

            Reset

        </a>

    </form>

    <% if(error){ %>

        <div class="no-results">

            <%= error %>

        </div>

    <% } %>

    <% if(results.length > 0){ %>

        <h3 class="search-results">

            <%= results.length %> breed(s) found

        </h3>

    <% } %>

    <% if(results.length === 0 && keyword){ %>

        <div class="no-results">

            No breeds found.

        </div>

    <% } %>

    <div id="catsContainer">

        <% results.forEach(breed => { %>

            <div class="card">

                <img
                    src="<%= breed.image_url %>"
                    alt="<%= breed.name %>">

                <div class="card-content">

                    <h3>

                        <%= breed.name %>

                    </h3>

                    <p>

                        <strong>Origin:</strong>

                        <%= breed.origin %>

                    </p>

                    <p>

                        <strong>Life Span:</strong>

                        <%= breed.details.lifespan %>

                    </p>

                    <p>

                        <strong>Weight:</strong>

                        <%= breed.details.weight %>

                    </p>

                    <p>

                        <strong>Coat Type:</strong>

                        <%= breed.details.coatType %>

                    </p>

                    <p>

                        <strong>Temperament:</strong>

                        <%= breed.temperament %>

                    </p>

                    <a
                        href="/breeds/<%= breed.id %>"
                        class="btn">

                        View Details

                    </a>

                </div>

            </div>

        <% }) %>

    </div>

</section>

<%- include("partials/footer") %>