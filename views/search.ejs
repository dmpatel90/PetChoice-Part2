<%- include("partials/header") %>

<%- include("partials/navbar") %>

<section class="about">

<h1 class="about-title">

Search Cat Breeds

</h1>

<form action="/search" method="POST" class="controls">

<input

type="text"

name="keyword"

placeholder="Search breed, origin or temperament..."

value="<%= keyword %>"

required>

<button type="submit">

Search

</button>

</form>

<br>

<% if(results.length === 0 && keyword){ %>

<h2>

No results found.

</h2>

<% } %>

<div id="catsContainer">

<% results.forEach(breed=>{ %>

<div class="card">

<img

src="<%= breed.image_url %>"

alt="<%= breed.name %>">

<div class="card-content">

<h3>

<%= breed.name %>

</h3>

<p>

<strong>Origin:</strong>

<%= breed.origin %>

</p>

<p>

<strong>Life Span:</strong>

<%= breed.details.lifespan %>

</p>

<p>

<strong>Weight:</strong>

<%= breed.details.weight %>

</p>

<p>

<strong>Coat:</strong>

<%= breed.details.coatType %>

</p>

<p>

<%= breed.description %>

</p>

<a

href="/breeds/<%= breed.id %>"

class="btn">

View Details

</a>

</div>

</div>

<% }) %>

</div>

</section>

<%- include("partials/footer") %>
