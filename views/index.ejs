<%- include("partials/header") %>

<%- include("partials/navbar") %>

<!-- ==========================================
     HERO SECTION
========================================== -->

<section class="hero">

    <div class="hero-content">

        <h2>
            Find Your Perfect Cat Breed
        </h2>

        <p>
            Pet Choice helps users explore different cat breeds and learn
            about their origin, temperament, lifespan, coat type, and
            grooming needs before choosing the perfect feline companion.
        </p>

        <a href="/breeds" class="btn">

            Browse Cat Breeds

        </a>

    </div>

</section>

<!-- ==========================================
     FEATURES
========================================== -->

<section class="features">

    <div class="feature-card">

        <h3>🐱 Browse Cat Breeds</h3>

        <p>
            Explore a collection of cat breeds and
            discover their unique characteristics,
            personalities, and origins.
        </p>

    </div>

    <div class="feature-card">

        <h3>🔍 Advanced Search</h3>

        <p>
            Search breeds by name, origin,
            temperament, coat type, and
            grooming level.
        </p>

    </div>

    <div class="feature-card">

        <h3>❤️ Compare Breeds</h3>

        <p>
            Compare breed characteristics
            to find the perfect cat that
            matches your lifestyle.
        </p>

    </div>

</section>

<!-- ==========================================
     ABOUT
========================================== -->

<section class="about">

    <h2>

        Why Pet Choice?

    </h2>

    <p>

        Pet Choice is designed to help cat lovers learn about
        different cat breeds through a local JSON dataset.
        Users can browse breed information, search using
        multiple filters, and view detailed descriptions,
        making it easier to understand each breed before
        choosing a feline companion.

    </p>

</section>

<!-- ==========================================
     STATISTICS
========================================== -->

<section class="stats">

    <div class="stat">

        <h2><%= breeds.length %></h2>

        <p>Cat Breeds</p>

    </div>

    <div class="stat">

        <h2>6+</h2>

        <p>Search Filters</p>

    </div>

    <div class="stat">

        <h2>100%</h2>

        <p>Breed Information</p>

    </div>

</section>

<!-- ==========================================
     QUICK FACTS
========================================== -->

<section class="features">

    <div class="feature-card">

        <h3>🌎 Worldwide Breeds</h3>

        <p>
            Learn about cat breeds from different
            countries around the world, including
            their history and origin.
        </p>

    </div>

    <div class="feature-card">

        <h3>🛁 Grooming Information</h3>

        <p>
            Find out each breed's coat type,
            grooming needs, and care
            requirements.
        </p>

    </div>

    <div class="feature-card">

        <h3>📖 Detailed Profiles</h3>

        <p>
            View detailed information including
            temperament, lifespan, weight,
            and descriptions for every breed.
        </p>

    </div>

</section>

<%- include("partials/footer") %>